# ══════════════════════════════════════════════════════════════════════════
# API CONFIGURATION — Seacrest Monitor de Barreiras
# ══════════════════════════════════════════════════════════════════════════

# "mock" (default) uses the deterministic in-memory generator (lib/data.ts).
# "http" switches every data call to a real backend via lib/api.ts httpAdapter.
NEXT_PUBLIC_API_MODE=mock

# Only used when NEXT_PUBLIC_API_MODE=http. Root URL of your backend, with
# no trailing slash. Endpoints expected:
#   GET /api/barriers?<query>   -> BarriersResponse (see lib/wireTypes.ts)
#   GET /api/barriers/:id       -> WireBarrier
#   GET /api/kpi?locationId=<n> -> WireKpiSnapshot
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
